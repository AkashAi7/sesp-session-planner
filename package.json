{
  "name": "sesp-session-planner",
  "displayName": "Forge — Customer Engagement Studio",
  "description": "GitHub Copilot-powered engagement studio for Solution Engineers. Brief a customer once, generate hackathons, end-to-end labs, challenges with acceptance criteria, gatekeepers, and architecture — auto-saved into your workspace and optionally published as a customer-sharable repo.",
  "version": "0.5.0",
  "publisher": "sesp",
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=18"
  },
  "categories": ["AI", "Chat", "Other"],
  "keywords": [
    "github copilot",
    "copilot sdk",
    "azure",
    "hackathon",
    "solution engineer",
    "engagement",
    "customer",
    "forge"
  ],
  "activationEvents": [
    "onChatParticipant:sesp.planner",
    "onView:sesp.plannerView",
    "onView:sesp.historyView",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "sesp.planner",
        "name": "forge",
        "fullName": "Forge",
        "description": "Plan hackathons, end-to-end labs, challenges with acceptance criteria, and gatekeepers for Azure + GitHub.",
        "isSticky": true,
        "commands": [
          { "name": "hackathon", "description": "Design a hackathon agenda with modules, challenges, and gatekeepers." },
          { "name": "lab", "description": "Generate an end-to-end lab: provisioning → app → gatekeeper → troubleshooting → cleanup." },
          { "name": "challenge", "description": "Generate a goal-oriented challenge with acceptance criteria and progressive hints." },
          { "name": "onboarding", "description": "Generate prerequisite checklist and environment setup scripts." },
          { "name": "gatekeeper", "description": "Generate a validation script / GitHub Action that checks every acceptance criterion." },
          { "name": "architecture", "description": "Mix and match Azure + GitHub products into a cohesive architecture." }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sesp",
          "title": "Forge",
          "icon": "media/sesp.svg"
        }
      ]
    },
    "views": {
      "sesp": [
        {
          "id": "sesp.plannerView",
          "name": "Planner",
          "type": "webview",
          "icon": "media/sesp.svg",
          "contextualTitle": "Forge Planner"
        },
        {
          "id": "sesp.historyView",
          "name": "History",
          "icon": "media/sesp.svg",
          "contextualTitle": "Forge History"
        }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "sesp.newPlan", "when": "view == sesp.plannerView", "group": "navigation" },
        { "command": "sesp.openSettings", "when": "view == sesp.plannerView", "group": "navigation@2" },
        { "command": "sesp.clearHistory", "when": "view == sesp.historyView", "group": "navigation" },
        { "command": "sesp.refreshHistory", "when": "view == sesp.historyView", "group": "navigation@2" }
      ],
      "view/item/context": [
        { "command": "sesp.rerunFromHistory", "when": "view == sesp.historyView && viewItem == sespHistoryEntry", "group": "inline" },
        { "command": "sesp.createCustomerRepoForEntry", "when": "view == sesp.historyView && viewItem == sespHistoryEntry", "group": "1_actions" },
        { "command": "sesp.deleteFromHistory", "when": "view == sesp.historyView && viewItem == sespHistoryEntry", "group": "inline@2" }
      ],
      "commandPalette": [
        { "command": "sesp.rerunFromHistory", "when": "false" },
        { "command": "sesp.deleteFromHistory", "when": "false" },
        { "command": "sesp.createCustomerRepoForEntry", "when": "false" },
        { "command": "sesp.openHistoryEntry", "when": "false" }
      ]
    },
    "commands": [
      { "command": "sesp.openPlanner", "title": "Forge: Open Planner", "category": "Forge", "icon": "$(flame)" },
      { "command": "sesp.newPlan", "title": "New Engagement", "category": "Forge", "icon": "$(add)" },
      { "command": "sesp.quickStart", "title": "Forge: Quick Start (wizard)", "category": "Forge", "icon": "$(wand)" },
      { "command": "sesp.generateSessionPlan", "title": "Forge: Generate Full Session Plan", "category": "Forge" },
      { "command": "sesp.generateLab", "title": "Forge: Generate Lab Guide", "category": "Forge" },
      { "command": "sesp.generateGatekeeper", "title": "Forge: Generate Gatekeeper Validation", "category": "Forge" },
      { "command": "sesp.openSettings", "title": "Open Forge Settings", "category": "Forge", "icon": "$(gear)" },
      { "command": "sesp.clearHistory", "title": "Clear History", "category": "Forge", "icon": "$(clear-all)" },
      { "command": "sesp.refreshHistory", "title": "Refresh History", "category": "Forge", "icon": "$(refresh)" },
      { "command": "sesp.rerunFromHistory", "title": "Rerun", "icon": "$(play)" },
      { "command": "sesp.deleteFromHistory", "title": "Delete", "icon": "$(trash)" },
      { "command": "sesp.openHistoryEntry", "title": "Open", "category": "Forge" },
      { "command": "sesp.createCustomerRepoForEntry", "title": "Create customer repo…", "category": "Forge", "icon": "$(repo)" }
    ],
    "configuration": {
      "title": "Forge",
      "properties": {
        "sesp.model": {
          "type": "string",
          "default": "gpt-4.1",
          "enum": ["gpt-4.1", "claude-sonnet-4.5", "gpt-5"],
          "description": "Model used by the GitHub Copilot SDK session."
        },
        "sesp.useCopilotSdk": {
          "type": "boolean",
          "default": true,
          "description": "Route requests through @github/copilot-sdk (requires Copilot CLI). If false, falls back to VS Code's Language Model API."
        },
        "sesp.cliPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to the Copilot CLI executable. Leave empty to use the system PATH."
        },
        "sesp.cliUrl": {
          "type": "string",
          "default": "",
          "description": "Optional URL of a running Copilot CLI server (e.g., localhost:4321)."
        },
        "sesp.enableGithubMcp": {
          "type": "boolean",
          "default": true,
          "description": "Connect the session to GitHub's hosted MCP server for repo/issue/PR tools."
        },
        "sesp.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the Forge item in the status bar for one-click planner access."
        },
        "sesp.autoSaveToWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "After generation completes, automatically save materials under ./engagements/<customer-slug>/ in the current workspace."
        },
        "sesp.customerRepoDefaultVisibility": {
          "type": "string",
          "enum": ["private", "internal", "public"],
          "default": "private",
          "description": "Default visibility when creating a customer-sharable GitHub repository via the 'Create customer repo' action."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository --skip-license",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4"
  }
}
