.git/**
.vscode/**
.vscode-test/**
src/**
test/**
scripts/**
coverage/**
**/*.ts
**/*.map
tsconfig.json
vitest.config.ts
package-lock.json
.gitignore
RELEASE_NOTES_*.md
*.vsix

# Start from a deny-all node_modules stance, then re-include the exact runtime surface.
node_modules/**
!node_modules/@github/
!node_modules/@github/copilot/
!node_modules/@github/copilot/package.json
!node_modules/@github/copilot/index.js
!node_modules/@github/copilot/app.js
!node_modules/@github/copilot/npm-loader.js
!node_modules/@github/copilot/changelog.json
!node_modules/@github/copilot/conpty_console_list_agent.js
!node_modules/@github/copilot/tree-sitter*.wasm
!node_modules/@github/copilot/builtin-skills/**
!node_modules/@github/copilot/clipboard/**
!node_modules/@github/copilot/copilot-sdk/**
!node_modules/@github/copilot/definitions/**
!node_modules/@github/copilot/prebuilds/**
!node_modules/@github/copilot/preloads/**
!node_modules/@github/copilot/queries/**
!node_modules/@github/copilot/ripgrep/**
!node_modules/@github/copilot/schemas/**
!node_modules/@github/copilot/sdk/**
!node_modules/@github/copilot/sharp/**
!node_modules/@github/copilot/worker/**
!node_modules/@github/copilot-sdk/
!node_modules/@github/copilot-sdk/dist/**
!node_modules/@github/copilot-sdk/package.json
!node_modules/@github/copilot-win32-x64/
!node_modules/@github/copilot-win32-x64/copilot.exe
!node_modules/@github/copilot-win32-x64/package.json
!node_modules/vscode-jsonrpc/
!node_modules/vscode-jsonrpc/browser.js
!node_modules/vscode-jsonrpc/lib/**/*.js
!node_modules/vscode-jsonrpc/node.js
!node_modules/vscode-jsonrpc/node.cmd
!node_modules/vscode-jsonrpc/package.json

# Trim dependency docs, tests, sources, and type-only assets that are not needed at runtime.
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/src/**
node_modules/**/*.d.ts
node_modules/**/*.md
node_modules/**/*.ts
node_modules/**/*.map
node_modules/**/LICENSE*
node_modules/**/thirdpartynotices.txt
